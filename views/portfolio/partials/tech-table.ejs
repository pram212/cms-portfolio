<table class="table table-sm table-bordered">
  <thead class="bg-light text-center">
    <th>Programming</th>
    <th width="5%">
      <button class="btn btn-sm btn-success" id="btn-tambah-tech">
        <i class="fa fa-plus"></i>
      </button>
    </th>
  </thead>
  <tbody id="tech-list">
    <% data.teknologi.forEach(tech => { %>
    <tr>
      <td>
        <input
          type="text"
          name="teknologi[]"
          class="form-control form-control-sm"
          value="<%= tech %>"
        />
      </td>
      <td>
        <button type="button" class="btn btn-sm btn-danger btn-hapus-tech">
          <i class="fa fa-trash"></i>
        </button>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
